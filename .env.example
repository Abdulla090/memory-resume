# Server-side Gemini API key (required in production).
# Used for both standard Gemini chat completions and the Managed Agent
# (Antigravity) used by the Job Agent feature in /dashboard/job-agent.
#
# The Job Agent runs in BACKGROUND MODE on Google's infra: the start request
# returns an interaction id in ~1-2s, and the client polls a lightweight
# status endpoint every 5s until done. Every server function call in this
# flow finishes well under 10 seconds, so it works on the free tier of:
#   * Vercel Hobby
#   * Cloudflare Pages / Workers
#   * Netlify Functions
#   * Deno Deploy
# No paid extended-runtime tier is needed.
#
# Cost note: each scan still costs roughly 100k–3M tokens against your
# Gemini API quota, so the start endpoint enforces a 6 scans/hour per-IP cap.
GEMINI_API_KEY=

# Optional: allow users to pass their own API key from the browser (dev only)
# ALLOW_CLIENT_API_KEY=true

# AI rate limiting (per IP per operation per hour) for standard Gemini calls.
# The Job Agent (managed-agent) operations have their own caps and ignore this.
AI_RATE_LIMIT_MAX=40
AI_RATE_LIMIT_WINDOW_MS=3600000

# ─── Clerk (authentication) ───────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Supabase (database + RLS with Clerk JWT) ─────────────────────────────────
# Enable Clerk ↔ Supabase in both dashboards before using cloud sync.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Resend (transactional email — welcome, etc.) ─────────────────────────────
# Replace re_xxxxxxxxx with your real key: https://resend.com/api-keys
# Test send: npm run email:test
# Configure Clerk Dashboard → Email → Custom SMTP with Resend for auth emails.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_TEST_TO=you@example.com
RESEND_FROM_EMAIL=MemoryCV <hello@yourdomain.com>
APP_URL=http://localhost:3000

# Phase 3: Error monitoring (optional)
# VITE_SENTRY_DSN=
# SOURCEMAP=true
